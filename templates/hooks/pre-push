#!/bin/sh
# >>> code-quality managed hook >>>
# Installed by code-quality. Local hooks are bypassable and not server enforcement.
CQ_HOOK_MODE=warn
CQ_HOOK_PRESET=balanced
CQ_HOOK_PHASE=pre-push
CQ_HOOK_FAIL_OPEN=1
if ! command -v cq >/dev/null 2>&1; then
  echo "code-quality: cq not found; fail-open skip for pre-push" >&2
  exit 0
fi
cq hooks run pre-push --mode "$CQ_HOOK_MODE" --preset "$CQ_HOOK_PRESET"
status=$?
if [ "$CQ_HOOK_MODE" = "warn" ]; then
  exit 0
fi
exit $status
# <<< code-quality managed hook <<<
