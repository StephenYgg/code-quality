{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-quality.local/schemas/waiver.schema.json",
  "title": "Code Quality Waiver",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "ruleId",
    "ruleVersion",
    "repository",
    "scope",
    "reason",
    "riskAcceptance",
    "approver",
    "owner",
    "compensatingControls",
    "trackingIssue",
    "createdAt",
    "expiresAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]{2,127}$" },
    "ruleId": { "type": "string", "pattern": "^CQ-[A-Z]+-[0-9]{3}$" },
    "ruleVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": { "type": "integer", "minimum": 1 },
        "maximum": { "type": "integer", "minimum": 1 }
      }
    },
    "repository": { "type": "string", "minLength": 1, "maxLength": 300 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^*]+(?:/\\*|/\\*\\*)?$"
          }
        },
        "symbols": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "changes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        },
        "findings": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      }
    },
    "reason": { "type": "string", "minLength": 10, "maxLength": 4000 },
    "riskAcceptance": { "type": "string", "minLength": 10, "maxLength": 4000 },
    "approver": { "type": "string", "minLength": 2, "maxLength": 300 },
    "owner": { "type": "string", "minLength": 2, "maxLength": 300 },
    "compensatingControls": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "minLength": 10, "maxLength": 2000 }
    },
    "trackingIssue": { "type": "string", "minLength": 3, "maxLength": 1000 },
    "createdAt": { "$ref": "#/$defs/timestamp" },
    "expiresAt": { "$ref": "#/$defs/timestamp" }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{3})?Z$"
    }
  }
}
