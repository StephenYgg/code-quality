{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-quality.local/schemas/finding.schema.json",
  "title": "Code Quality Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "ruleId",
    "ruleVersion",
    "title",
    "severity",
    "confidence",
    "status",
    "disposition",
    "locations",
    "trigger",
    "actualBehavior",
    "expectedBehavior",
    "impact",
    "evidence",
    "remediation",
    "verification",
    "reviewStage",
    "provider",
    "model",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": { "const": "1" },
    "id": { "type": "string", "minLength": 1, "maxLength": 300 },
    "ruleId": { "type": "string", "pattern": "^CQ-[A-Z]+-[0-9]{3}$" },
    "ruleVersion": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 3, "maxLength": 300 },
    "severity": { "enum": ["P0", "P1", "P2", "P3", "NIT"] },
    "confidence": { "enum": ["low", "medium", "high", "deterministic"] },
    "status": {
      "enum": [
        "candidate",
        "corroborated",
        "confirmed",
        "reported",
        "dismissed",
        "uncertain",
        "waived"
      ]
    },
    "disposition": {
      "enum": ["new", "preexisting", "unknown", "not_applicable"]
    },
    "locations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "startLine", "endLine"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "startLine": { "type": "integer", "minimum": 1 },
          "endLine": { "type": "integer", "minimum": 1 },
          "startColumn": { "type": "integer", "minimum": 1 },
          "endColumn": { "type": "integer", "minimum": 1 },
          "symbol": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    },
    "trigger": { "$ref": "#/$defs/explanation" },
    "actualBehavior": { "$ref": "#/$defs/explanation" },
    "expectedBehavior": { "$ref": "#/$defs/explanation" },
    "impact": { "$ref": "#/$defs/explanation" },
    "evidence": { "$ref": "#/$defs/evidenceList" },
    "remediation": { "$ref": "#/$defs/explanation" },
    "verification": { "$ref": "#/$defs/evidenceList" },
    "reviewStage": { "type": "string", "minLength": 2, "maxLength": 120 },
    "provider": { "type": "string", "minLength": 2, "maxLength": 120 },
    "model": { "type": "string", "minLength": 1, "maxLength": 300 },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt"],
      "properties": {
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "updatedAt": { "$ref": "#/$defs/timestamp" },
        "verifiedAt": { "$ref": "#/$defs/timestamp" }
      }
    }
  },
  "$defs": {
    "explanation": { "type": "string", "minLength": 5, "maxLength": 10000 },
    "evidenceList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "type": "string", "minLength": 3, "maxLength": 10000 }
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{3})?Z$"
    }
  }
}
